# HerdFlow backend — local dev ($0). Copy to .env.local and adjust.
# Local Postgres (Docker):  docker run -e POSTGRES_PASSWORD=dev -p 5432:5432 postgres:16
DATABASE_URL=postgresql://postgres:dev@localhost:5432/postgres
# Session cookie signing secret (any random string for local dev)
SESSION_SECRET=dev-change-me-please

# Alerts (OPTIONAL). Leave unset → $0 dry-run: the pipeline runs and logs what it
# WOULD send, but nothing is delivered or charged. Set a key to send for real.
# RESEND_API_KEY=
# ALERTS_FROM=HerdFlow <alerts@herdflow.app>
