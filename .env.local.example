# HerdFlow — Supabase configuration
# Copy this file to `.env.local` and fill in the values from your Supabase project
# (Dashboard → Project Settings → Data API). `.env.local` is gitignored:
# NEVER commit real keys to the repo.

# Project URL, e.g. https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public anon / publishable key — safe to expose in the browser.
# Access is still enforced server-side by Row Level Security (RLS).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
